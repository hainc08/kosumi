# Sao chép file này thành .env (cùng thư mục deploy/) trên server và điền thật.
# .env KHÔNG được commit (đã gitignore) → git pull không đụng tới file này.
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
PORT=3000
NODE_ENV=production

# Chạy app theo giờ UTC để created_at/updated_at nhất quán (tránh lệch múi giờ).
TZ=UTC

# ─── Log điều tra bug ───────────────────────────────────────────
# Mức log: debug | info | warn | error  (mặc định info)
LOG_LEVEL=info
# Thư mục ghi log (mặc định <app>/logs). Có thể trỏ ra ngoài để git pull không đụng.
# LOG_DIR=/var/www/vhosts/poc.kosumi.vn/logs
# Đặt 'false' nếu chỉ muốn log ra stdout (Plesk Node.js log), không ghi file.
LOG_TO_FILE=true
# Token để xem log qua API: GET /api/logs/tail?token=...&lines=200
# BẮT BUỘC đặt ở production thì endpoint xem log mới mở (nếu trống → bị chặn).
LOG_VIEW_TOKEN=

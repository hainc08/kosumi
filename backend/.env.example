DATABASE_HOST=localhost
DATABASE_PORT=3307
DATABASE_USER=user
DATABASE_PASSWORD=pass
DATABASE_NAME=workshop_pro
REDIS_URL=redis://localhost:6379
PORT=3000

# Giờ UTC cho timestamp nhất quán
TZ=UTC
# Log điều tra: LOG_LEVEL=debug|info|warn|error, LOG_TO_FILE=true|false,
# LOG_VIEW_TOKEN để mở GET /api/logs/tail?token=...
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_VIEW_TOKEN=dev-token
